---
import {
  Mail,
  Download,
  Search,
  Menu,
  X,
  Phone,
  MapPin,
  User,
  Briefcase,
  ArrowRight
} from "@lucide/astro";

const { name, size = 20 } = Astro.props;

const icons = {
  email: Mail,
  download: Download,
  search: Search,
  menu: Menu,
  close: X,
  phone: Phone,
  location: MapPin,
  user: User,
  work: Briefcase,
  arrow: ArrowRight,
} as const;

const Icon = icons[name as keyof typeof icons];
---

{Icon && <Icon size={size} />}