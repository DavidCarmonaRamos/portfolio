---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import ArrowCard from "@components/ArrowCard"
import StackCard from "@components/StackCard.astro"
import { SITE, SOCIALS } from "@consts"
import TwinklingStars from "@components/TwinklingStars.astro"
import MeteorShower from "@components/MeteorShower.astro"

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0,3)

const stack = [
  {
    text: "JavaScript",
    icon: "javascript",
    href: "https://developer.mozilla.org/es/docs/Web/JavaScript",
  },
  {
    text: "TypeScript",
    icon: "typescript",
    href: "https://www.typescriptlang.org/",
  },
  {
    text: "Astro",
    icon: "astro",
    href: "https://astro.build/",
  }
]
---

<PageLayout title={SITE.TITLE} description={SITE.DESCRIPTION}>

  <!-- Light Mode: Particles -->
  <div class='absolute inset-0 block dark:hidden'>
    <div id='particles1' class='fixed inset-0'></div>
    <div id='particles2' class='fixed inset-0'></div>
    <div id='particles3' class='fixed inset-0'></div>
  </div>

  <!-- Dark Theme: Stars -->
  <div class='absolute inset-0 bg-black hidden dark:block'>
    <div id='stars1' class='fixed inset-0'></div>
    <div id='stars2' class='fixed inset-0'></div>
    <div id='stars3' class='fixed inset-0'></div>
  </div>

  <!-- Dark Theme: Twinkling Stars / Metors -->
  <div id="galaxy" class="fixed inset-0">
    <div class="hidden dark:block">
      <TwinklingStars/>
      <MeteorShower/>
    </div>
  </div>

  <script is:inline src="/js/bg.js"></script>
  
  <!-- HERO -->
  <section class="relative h-screen w-full">
    <div class="animate absolute h-full w-full flex items-center justify-center">
      <div class='relative w-full h-full flex items-center justify-center'>
        <div class='p-5 text-center'>
          <p class='animated text-lg md:text-xl lg:text-2xl font-semibold opacity-75'>
            Desarrollador Web · Técnico en Sistemas Microinformáticos y Redes
          </p>

          <p class='animated text-3xl md:text-5xl lg:text-6xl font-bold uppercase text-black dark:text-white mt-2'>
            David Carmona Ramos
          </p>

          <p class='animated mt-6 max-w-xl mx-auto text-base md:text-lg opacity-75'>
            Desarrollo aplicaciones web, administro sistemas y disfruto creando soluciones tecnológicas que combinan funcionalidad, diseño y aprendizaje continuo.
          </p>
          <div id="ctaButtons" class='animated flex flex-wrap gap-4 justify-center mt-8'>
            <a href="/projects" class='py-3 px-6 rounded bg-black dark:bg-white text-white dark:text-black hover:opacity-80 blend'>
              Ver proyectos
            </a>
            <a href='/work' class='py-3 px-4 truncate rounded text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 blend'>
              Experiencia
            </a>
            <a href="/cv.pdf" class='py-3 px-6 rounded border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/10 blend'>
              Descargar CV
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="relative bg-white dark:bg-black">
    <div class="mx-auto max-w-screen-sm p-5 space-y-24 pb-16">

      <!-- About Section -->
      <section class="animate">
        <article>
          <h2 class="text-2xl font-bold text-black dark:text-white mb-6">
              Sobre mí
          </h2>
          <p>Soy Técnico en Sistemas Microinformáticos y Redes con interés en el desarrollo web, la administración de sistemas y la creación de aplicaciones.</p>
          <article class="space-y-5"></article>
          <p>Me gusta aprender nuevas tecnologías y afrontar proyectos que me permitan seguir creciendo profesionalmente. Actualmente desarrollo proyectos personales para ampliar mis conocimientos y construir un portfolio que refleje mi evolución como desarrollador.</p>
          <article class="space-y-5"></article>
          <p>Actualmente estoy ampliando mis conocimientos en desarrollo web moderno, con especial interés en Astro, TypeScript y el desarrollo de aplicaciones escalables.</p>
        </article>
      </section>
      <!-- Especialidades -->
      <section class="animate">
        <h2 class="text-2xl font-bold text-black dark:text-white mb-8">
          Especialidades
        </h2>

        <div class="grid gap-6 md:grid-cols-3">

          <!-- Desarrollo Web -->
          <article class="rounded-xl border border-black/10 dark:border-white/10 p-6">
            <div class="text-4xl mb-4">
              💻
            </div>

            <h3 class="text-lg font-semibold mb-3 text-black dark:text-white">
              Desarrollo Web
            </h3>

            <p class="text-sm opacity-80 leading-relaxed">
              Desarrollo páginas web y aplicaciones modernas utilizando HTML, CSS, JavaScript, TypeScript y Astro.
            </p>
          </article>

          <!-- Sistemas -->
          <article class="rounded-xl border border-black/10 dark:border-white/10 p-6">
            <div class="text-4xl mb-4">
              🖥️
            </div>

            <h3 class="text-lg font-semibold mb-3 text-black dark:text-white">
              Sistemas y Redes
            </h3>

            <p class="text-sm opacity-80 leading-relaxed">
              Administración y mantenimiento de sistemas Windows y Linux, resolución de incidencias y soporte técnico.
            </p>
          </article>

          <!-- Aprendizaje -->
          <article class="rounded-xl border border-black/10 dark:border-white/10 p-6">
            <div class="text-4xl mb-4">
              📚
            </div>

            <h3 class="text-lg font-semibold mb-3 text-black dark:text-white">
              Aprendizaje Continuo
            </h3>

            <p class="text-sm opacity-80 leading-relaxed">
              Siempre aprendiendo nuevas tecnologías y desarrollando proyectos personales para seguir creciendo profesionalmente.
            </p>
          </article>

        </div>
      </section>
      <!-- Tech Stack Section -->
      <section class="animate">
        <div class="space-y-4">
          <p class="font-semibold text-black dark:text-white">
            Tecnologías
          </p>
          <div class="flex flex-wrap items-center gap-2 mt-5">
            {stack.map(item => (
              <StackCard 
                text={item.text}
                icon={item.icon}
                href={item.href}
              />
            ))}
          </div>
        </div>
      </section>

      <!-- Project Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p class="font-semibold text-black dark:text-white">
              Proyectos destacados
            </p>
            <a href="/projects" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                Ver todos
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {projects.map((project) => (
              <li>
                <ArrowCard entry={project} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Contact Section -->
      <section id="contact" class="animate">
        <div>
          <p class="font-semibold text-black dark:text-white">
            Contacto
          </p>
          <p>
            Si quieres contactar conmigo o conocer más sobre mi trabajo, puedes contactar conmigo mediante cualquiera de estos medios.
          </p>
          <div class="grid grid-cols-4 gap-y-2 mt-4 auto-cols-min">
            {SOCIALS.map(social => (
              <div class="col-span-1 flex items-center gap-1">
                <span class="whitespace-nowrap truncate">
                  {social.NAME}
                </span>
              </div>
              <div class="col-span-3 truncate">
                <a href={social.HREF} target="_blank" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
                  <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                    {social.TEXT}
                  </span>
                </a>
              </div>
            ))}
        </div>
      </section>
    </div>
  </div>
</PageLayout>
